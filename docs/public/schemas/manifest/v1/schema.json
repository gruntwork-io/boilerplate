{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boilerplate.gruntwork.io/schemas/manifest/v1/schema.json",
  "properties": {
    "SchemaVersion": {
      "type": "string"
    },
    "Timestamp": {
      "type": "string"
    },
    "TemplateURL": {
      "type": "string"
    },
    "BoilerplateVersion": {
      "type": "string"
    },
    "OutputDir": {
      "type": "string"
    },
    "Files": {
      "items": {
        "properties": {
          "Path": {
            "type": "string"
          },
          "Checksum": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "Path",
          "Checksum"
        ]
      },
      "type": "array"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "SchemaVersion",
    "Timestamp",
    "TemplateURL",
    "BoilerplateVersion",
    "OutputDir",
    "Files"
  ],
  "title": "Boilerplate Manifest Schema",
  "description": "Schema for boilerplate generation manifest"
}
